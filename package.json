{
  "name": "privacyshield-ai",
  "description": "PrivacyShield AI – Next Generation Privacy & Ad Blocking Browser Extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:zip": "npm run build && powershell Compress-Archive -Path dist/* -DestinationPath privacyshield-ai.zip -Force",
    "lint": "eslint src popup options --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"popup/**/*.{ts,tsx}\" \"options/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "prettier": "^3.9.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
